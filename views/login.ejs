<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">

<title>تسجيل الدخول - لجنة الخدمات الاجتماعية</title>

<style>
body {
    font-family: 'Cairo', sans-serif;
    background: linear-gradient(135deg, #0d6efd, #0a58ca);
    height: 100vh;
}

/* Card */
.login-card {
    width: 380px;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
}

/* Header */
.login-header {
    text-align: center;
}

.login-header img {
    width: 70px;
    margin-bottom: 10px;
}

.login-header h5 {
    font-weight: 700;
    color: #0d6efd;
}

/* Inputs */
.form-control {
    border-radius: 10px;
}

/* Button */
.btn-primary {
    border-radius: 10px;
    font-weight: bold;
}

/* Footer text */
.footer-text {
    font-size: 13px;
    color: #6c757d;
}
</style>

</head>

<body class="d-flex justify-content-center align-items-center">

<div class="card login-card p-4 bg-white">

    <!-- Header -->
    <div class="login-header mb-3">
        <!-- يمكنك تغيير الصورة -->
        <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" alt="logo">
        <h5>اللجنة الولائية للخدمات الاجتماعية</h5>
        <small class="text-muted">ولاية بشار</small>
    </div>

    <!-- Title -->
    <h4 class="text-center mb-3">🔐 تسجيل الدخول</h4>

    <!-- Form -->
    <form method="POST" action="/login">

        <input name="email" type="email" class="form-control mb-3" placeholder="📧 البريد الإلكتروني" required>

        <input name="password" type="password" class="form-control mb-3" placeholder="🔑 كلمة المرور" required>

        <button class="btn btn-primary w-100 mb-2">دخول</button>

    </form>

    <!-- Footer -->
    <div class="text-center footer-text mt-2">
        © جميع الحقوق محفوظة - ولاية بشار
    </div>

</div>

<!-- Toast -->
<div class="position-fixed top-0 start-50 translate-middle-x p-3" style="z-index: 1100;">
    <div id="toastEl" class="toast align-items-center text-white border-0">
        <div class="d-flex">
            <div class="toast-body" id="toastBody"></div>
            <button class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const params = new URLSearchParams(window.location.search);
    const toast = params.get("toast");

    const toastEl = document.getElementById("toastEl");
    const toastBody = document.getElementById("toastBody");

    if(!toast) return;

    switch(toast){
        case "invalid_login":
            toastEl.className = "toast align-items-center text-white bg-danger border-0";
            toastBody.innerText = "⚠️ البريد أو كلمة المرور غير صحيحة";
            break;
        case "logout":
            toastEl.className = "toast align-items-center text-white bg-success border-0";
            toastBody.innerText = "✅ تم تسجيل الخروج بنجاح";
            break;
    }

    const bsToast = new bootstrap.Toast(toastEl, { delay: 4000 });
    bsToast.show();
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>